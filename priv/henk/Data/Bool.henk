-- Boolean operations (Miranda-like, Church-encoded by compiler)

module Data.Bool where

import Prelude

not b = case b of
    True  -> False
    False -> True

and a b = case a of
    True  -> b
    False -> False

or a b = case a of
    True  -> True
    False -> b

bool_if b t f = case b of
    True  -> t
    False -> f
